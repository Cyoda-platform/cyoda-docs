---
// src/components/GrowthPathDiagram.astro — horizontal stepper of the
// four storage-engine tiers. Numbered circles on a shared line with
// arrow connectors between them; tier name and description stack
// beneath each circle.
//
// No media-query breakpoint: the 4-column grid stays at all widths
// and captions wrap naturally as space shrinks. Arrow geometry is
// deterministic because the circle has a fixed 1.9rem diameter.
const tiers = [
  { name: 'In-Memory',  sub: 'local dev + AI iteration',     variant: 'teal' },
  { name: 'SQLite',     sub: 'embedded durable single node', variant: 'teal' },
  { name: 'PostgreSQL', sub: 'durable clustered production', variant: 'teal' },
  { name: 'Cassandra',  sub: 'enterprise distributed scale', variant: 'green' },
];
---
<div class="gp-wrap">
  <ol class="gp">
    {tiers.map((t, i) => (
      <li class={`gp__step gp__step--${t.variant}`}>
        <span class="gp__num" aria-hidden="true">{i + 1}</span>
        <div class="gp__name">{t.name}</div>
        <div class="gp__sub">{t.sub}</div>
        {i < tiers.length - 1 && (
          <span class="gp__arrow" aria-hidden="true"></span>
        )}
      </li>
    ))}
  </ol>
</div>

<style>
  .gp-wrap {
    padding: 1.5rem 1.25rem 1.25rem;
    margin: 1.5rem 0;
    background: hsl(var(--cyoda-teal) / 0.04);
    border: 1px solid hsl(var(--cyoda-teal) / 0.2);
    border-radius: 0.5rem;
  }

  .gp {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    padding: 0;
    margin: 0;
  }

  .gp__step {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0 0.5rem;
    text-align: center;
  }

  .gp__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 9999px;
    font-family: var(--cyoda-font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    background: hsl(var(--cyoda-teal));
    color: white;
    margin-bottom: 0.2rem;
    flex-shrink: 0;
  }
  .gp__step--green .gp__num {
    background: hsl(var(--cyoda-green));
  }

  .gp__name {
    font-family: var(--cyoda-font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: hsl(var(--cyoda-foreground));
    line-height: 1.2;
  }
  .gp__sub {
    font-size: 0.9rem;
    line-height: 1.35;
    color: hsl(var(--cyoda-foreground) / 0.85);
  }

  /* Arrow: absolute-positioned between current circle's right edge
   * and next circle's left edge. Vertically centred on the circle
   * midline via `top: 0.95rem` + `translateY(-50%)`. */
  .gp__arrow {
    position: absolute;
    top: 0.95rem;
    left: calc(50% + 0.95rem + 0.15rem);
    width: calc(100% - 1.9rem - 0.3rem);
    height: 0.75rem;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    color: hsl(var(--cyoda-teal) / 0.55);
    pointer-events: none;
  }
  .gp__arrow::before {
    content: '';
    flex: 1;
    height: 2px;
    background: currentColor;
  }
  .gp__arrow::after {
    content: '';
    width: 0;
    height: 0;
    border-left: 7px solid currentColor;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    margin-left: -1px;
  }
</style>
