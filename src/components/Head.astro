---
// Custom Head component that extends Starlight's default Head
// Includes optimized Analytics component and hash redirect handling
import StarlightHead from '@astrojs/starlight/components/Head.astro';
import Analytics from './Analytics.astro';
import HashRedirect from './HashRedirect.astro';

// Starlight exposes per-route data via Astro.locals.starlightRoute (not Astro.props).
// See node_modules/@astrojs/starlight/utils/routing/types.ts (StarlightRouteData).
// `entry.slug` is the content-collection slug for the current page (e.g.
// "getting-started/quickstart" or "" for the root index). The markdown export
// pipeline (scripts/export-markdown.js) mirrors the file tree under /markdown/,
// so the slug maps 1:1 to /markdown/<slug>.md.
const starlightRoute = Astro.locals.starlightRoute;
const slug = starlightRoute?.entry?.slug ?? '';
const mdPath = slug === '' ? '/markdown/index.md' : `/markdown/${slug}.md`;

const entry = starlightRoute?.entry;
const title = entry?.data?.title ?? 'Cyoda Documentation';
const description = entry?.data?.description ?? '';
const ld = {
  '@context': 'https://schema.org',
  '@type': 'TechnicalArticle',
  headline: title,
  description,
  inLanguage: 'en',
  isPartOf: { '@type': 'WebSite', name: 'Cyoda Documentation', url: 'https://docs.cyoda.net' },
  dateModified: entry?.data?.lastUpdated ?? new Date().toISOString().slice(0, 10),
};
---

{/*
  Security: limit referrer leakage on outbound navigations and asset loads.
  GitHub Pages cannot set HTTP response headers; this <meta> is the
  highest-impact security policy we can set declaratively.

  Note: a Content-Security-Policy meta is intentionally NOT set here.
  The site uses several Astro `define:vars` inline scripts whose hashes
  change on every build, and meta CSP cannot use `frame-ancestors`. A real
  CSP requires fronting docs.cyoda.net with a CDN that can set headers.
*/}
<meta name="referrer" content="strict-origin-when-cross-origin" />

{/* Per-page markdown for LLM consumers */}
<link rel="alternate" type="text/markdown" href={mdPath} title="View as Markdown" />

{/* Site-wide LLM indexes */}
<link rel="alternate" type="text/markdown" href="/llms.txt" title="LLM index" />
<link rel="alternate" type="text/markdown" href="/llms-full.txt" title="Full content for LLMs" />

<script type="application/ld+json" set:html={JSON.stringify(ld)} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="preload"
  as="style"
  href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap"
  onload="this.onload=null;this.rel='stylesheet'"
/>
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" />
</noscript>

<StarlightHead {...Astro.props} />
<Analytics />
<HashRedirect />
